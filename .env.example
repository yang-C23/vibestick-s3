# vibestick-s3 bridge configuration. Copy to `.env` and edit. NEVER commit `.env`.
# All AI/STT keys live ONLY here on the Mac — never on the device.

# --- Bridge network ---
VIBESTICK_WS_PORT=47600            # device <-> bridge WebSocket
VIBESTICK_BIND=127.0.0.1           # bind localhost/LAN only; never expose publicly
VIBESTICK_MDNS_NAME=vibestick      # advertised as _vibestick._tcp.local

# --- Speech-to-text (local, Chinese-first; pluggable) ---
# Providers: qwen3-asr (default) | mimo | funasr | whispercpp | openai | doubao | mock
VIBESTICK_STT_PROVIDER=mock
VIBESTICK_STT_MODEL=qwen3-asr-0.6b
VIBESTICK_STT_SIDECAR_URL=http://127.0.0.1:47610  # local STT sidecar (MLX/C/FunASR)

# --- Prompt normalizer (local-first; pluggable) ---
# Backends: ollama (default) | deterministic | claude
VIBESTICK_NORMALIZER_BACKEND=deterministic
VIBESTICK_OLLAMA_URL=http://127.0.0.1:11434
VIBESTICK_OLLAMA_MODEL=qwen2.5:3b-instruct

# --- Optional cloud (OFF by default; only used if a provider/backend above is cloud) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=          # enables claude normalizer backend (claude-haiku-4-5)
# DOUBAO_API_KEY=             # Volcengine ASR

# --- Injection ---
VIBESTICK_INJECT_AUTOPASTE=false   # require Accessibility opt-in; NEVER auto-press Enter
